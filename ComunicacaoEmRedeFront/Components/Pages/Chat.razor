@page "/chat"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject HttpClient Http
@using System.Net.WebSockets
@using System.Text
@implements IAsyncDisposable

<h3>Chat</h3>

@if (carregando)
{
    <p>Carregando...</p>
}
else if (!conectado)
{
    <p>Conectando ao chat...</p>
}
else
{
    <div style="border:1px solid #ccc; height:400px; overflow-y:auto; padding:10px; margin-bottom:10px;">
        @foreach (var msg in mensagens)
        {
            <p>@msg</p>
        }
    </div>

    <input @bind="textoMensagem" @onkeydown="OnKeyDown" placeholder="Digite uma mensagem..." style="width:80%" />
    <button @onclick="EnviarMensagem">Enviar</button>
}

@if (!string.IsNullOrEmpty(erro))
{
    <p style="color:red">@erro</p>
}

@code {
    private ClientWebSocket? _ws;
    private System.Net.Sockets.NetworkStream? _stream;
    private CancellationTokenSource _cts = new();

    private List<string> mensagens = new();
    private string textoMensagem = "";
    private string erro = "";
    private bool conectado = false;
    private bool carregando = true;

    private Guid userId;
    private string email = "";
    private Guid chatId = Guid.Parse("00000000-0000-0000-0000-000000000001");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CarregarUsuarioAsync();
        }
    }

    private async Task CarregarUsuarioAsync()
    {
        try
        {
            var response = await Http.GetAsync("/v1/session/me");

            if (!response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/login");
                return;
            }

            var data = await response.Content.ReadFromJsonAsync<MeResponse>();
            userId = data!.Id;
            email = data.Email;

            carregando = false;
            StateHasChanged();

            await ConectarAsync();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar sessão: {ex.Message}";
            carregando = false;
            StateHasChanged();
        }
    }

    private async Task ConectarAsync()
    {
        try
        {
            _ws = new ClientWebSocket();

            var httpUri = Nav.ToAbsoluteUri("ws://localhost:5165/ws/chat");

            var wsUri = new UriBuilder(httpUri)
            {
                Scheme = httpUri.Scheme == "https" ? "wss" : "ws"
            }.Uri;
            
            await _ws.ConnectAsync(wsUri, _cts.Token);

            var auth = System.Text.Json.JsonSerializer.Serialize(new
            {
                UserId = userId,
                Email = email,
                ChatId = chatId
            });

            var authBytes = Encoding.UTF8.GetBytes(auth);
            await _ws.SendAsync(authBytes, WebSocketMessageType.Text, true, _cts.Token);

            conectado = true;
            StateHasChanged();

            _ = ReceberMensagensAsync();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao conectar: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task ReceberMensagensAsync()
    {
        var buffer = new byte[4096];

        try
        {
            while (_ws is not null && _ws.State == WebSocketState.Open)
            {
                var result = await _ws.ReceiveAsync(buffer, _cts.Token);

                if (result.MessageType == WebSocketMessageType.Close)
                    break;

                var msg = Encoding.UTF8.GetString(buffer, 0, result.Count);

                mensagens.Add(msg);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro na conexão: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task EnviarMensagem()
    {
        if (string.IsNullOrWhiteSpace(textoMensagem) || _ws is null)
            return;

        var bytes = Encoding.UTF8.GetBytes(textoMensagem);

        await _ws.SendAsync(bytes, WebSocketMessageType.Text, true, _cts.Token);

        textoMensagem = "";
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await EnviarMensagem();
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();

        if (_ws is not null)
        {
            await _ws.CloseAsync(WebSocketCloseStatus.NormalClosure, "Dispose", CancellationToken.None);
            _ws.Dispose();
        }
    }

    private record MeResponse(Guid Id, string Email);
}
